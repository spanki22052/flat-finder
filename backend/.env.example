# --- Server ---
PORT=3001
NODE_ENV=development

# --- Database (Postgres via Docker locally) ---
DATABASE_URL="postgresql://flatfinder:flatfinder@localhost:5432/flatfinder?schema=public"

# --- Auth ---
JWT_SECRET="change-me-in-prod-please-use-a-long-random-string"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10

# --- Parser ---
# PARSER_PROXY_URL=http://user:pass@proxy-host:port
# PARSER_HEADLESS=true